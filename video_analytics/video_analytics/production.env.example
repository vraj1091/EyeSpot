POSTGRES_DB=video_analytics
POSTGRES_USER=video_analytics
POSTGRES_PASSWORD=change-this-strong-db-password
SECRET_KEY=change-this-super-secret-jwt-key

# Comma-separated origins, no trailing slash
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# External HTTP port for frontend container
FRONTEND_PORT=80

# Distributed processing (set true in multi-worker setup)
ENABLE_DISTRIBUTED_WORKERS=false
CAMERA_RECONCILE_INTERVAL_SECONDS=15

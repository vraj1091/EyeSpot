# Copy this file to `.env` before deployment.
# If your frontend is not reverse-proxying `/api`, set a full backend URL:
# VITE_PORTFOLIO_API_BASE=https://your-backend-domain/api
FRONTEND_PORT=3000
VITE_PORTFOLIO_API_BASE=/api
VITE_ENABLE_PORTFOLIO_REMOTE_SYNC=true
# Nginx upstream used for /api proxy inside frontend container.
# Default uses local portfolio-api service (included in this compose).
# You can override with a full URL like https://api.yourdomain.com
PORTFOLIO_API_UPSTREAM=http://portfolio-api:8000
